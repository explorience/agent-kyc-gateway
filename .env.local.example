# Know Your Human (KYH) - Environment Variables
# Copy this to .env.local and fill in your values

# ===== Celo Network =====
# "mainnet" or "testnet" (EAS is only on mainnet)
CELO_NETWORK=mainnet
CELO_RPC=https://forno.celo.org

# ===== EAS (Ethereum Attestation Service) =====
# EAS contract on Celo mainnet (do not change)
EAS_CONTRACT=0x72E1d8ccf5299fb36fEfD8CC4394B8ef7e98Af92
SCHEMA_REGISTRY=0x5ece93bE4BDCF293Ed61FA78698B594F2135AF34

# Schema UID — register your schema first, then paste the UID here
# Schema: "uint8 level,string provider,bool demoMode"
KYH_SCHEMA_UID=

# ===== Issuer Wallet =====
# Private key for the wallet that signs EAS attestations
# Generate a new wallet, fund with a tiny amount of CELO for gas (~$0.01)
ISSUER_PRIVATE_KEY=0x...
ISSUER_ADDRESS=0x...

# ===== Provider API Keys =====
# Self Protocol — register at selfxyz.com
SELF_APP_ID=

# Human Passport — register at passport.xyz
HP_API_KEY=

# Didit — register at didit.me (500 free checks/month)
DIDIT_API_KEY=

# ===== Optional =====
# x402 facilitator address (for payment verification)
X402_FACILITATOR_ADDRESS=

# Webhook signing secret
WEBHOOK_SECRET=

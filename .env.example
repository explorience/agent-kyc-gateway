# KYH Gateway Configuration
# Copy this to .env.local and fill in your values

# === Celo Network ===
CELO_RPC=https://forno.celo.org

# === EAS (Ethereum Attestation Service) ===
EAS_CONTRACT=0x72E1d8ccf5299fb36fEfD8CC4394B8ef7e98Af92
SCHEMA_REGISTRY=0x5ece93bE4BDCF293Ed61FA78698B594F2135AF34
KYH_SCHEMA_UID=0x23b867f11eb49a6d94a6490e11aa2c4fd2dbbda5950b8444281ed2953daad5ab

# Issuer wallet (signs attestations, pays gas)
ISSUER_PRIVATE_KEY=your_private_key_here
ISSUER_ADDRESS=your_issuer_address_here

# === Human Passport (Reputation tier) ===
# Free API — get key at https://passport.xyz
HP_API_KEY=your_hp_api_key
HP_SCORER_ID=your_scorer_id

# === Self Protocol (Document tier) ===
# SDK-based, no API key needed
SELF_APP_ID=kyh-gateway

# === Didit (Biometric + Full KYC tiers) ===
# Get credentials at https://business.didit.me
DIDIT_APP_ID=your_didit_app_id
DIDIT_API_KEY=your_didit_api_key

# === Gateway ===
NEXT_PUBLIC_GATEWAY_URL=https://knowyourhuman.xyz
